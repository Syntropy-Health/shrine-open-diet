# Neo4j connection (Railway — use TCP proxy for reliable access)
NEO4J_URI=bolt://metro.proxy.rlwy.net:22971
NEO4J_USER=neo4j
NEO4J_PASSWORD=demodemo

# Alternative: Railway domain endpoint (may have DNS issues)
# NEO4J_URI=bolt://neo4j-test-2be3.up.railway.app:7687

# Alternative: Local Docker
# NEO4J_URI=bolt://localhost:7687

# Embedding server (LM Studio local)
EMBEDDING_BASE_URL=http://127.0.0.1:1234/v1
EMBEDDING_MODEL=text-embedding-embeddinggemma-300m-qat
EMBEDDING_DIM=768
EMBEDDING_API_KEY=not-needed

# LLM for entity extraction (LM Studio local)
LLM_BASE_URL=http://127.0.0.1:1234/v1
LLM_MODEL=
LLM_API_KEY=not-needed

# Ingestion limits (start small for experiments)
BATCH_SIZE=100
MAX_HERBS=100
MAX_COMPOUNDS=500
