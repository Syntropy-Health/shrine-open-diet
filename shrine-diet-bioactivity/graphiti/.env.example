# Graphiti integration — template only. Copy to `.env` and fill from
# Infisical "SyntropyHealth App" project. Never commit real credentials.
#
# NOTE: Graphiti is a legacy PoC superseded by LightRAG. See ../lightrag/.

# Neo4j — Aura Cloud
NEO4J_URI=neo4j+s://<instance-id>.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# Embedding server (LM Studio local)
EMBEDDING_BASE_URL=http://127.0.0.1:1234/v1
EMBEDDING_MODEL=text-embedding-embeddinggemma-300m-qat
EMBEDDING_DIM=768
EMBEDDING_API_KEY=not-needed

# LLM for entity extraction (LM Studio local)
LLM_BASE_URL=http://127.0.0.1:1234/v1
LLM_MODEL=
LLM_API_KEY=not-needed

# Ingestion limits (start small for experiments)
BATCH_SIZE=100
MAX_HERBS=100
MAX_COMPOUNDS=500
