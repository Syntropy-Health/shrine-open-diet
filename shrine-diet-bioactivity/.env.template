# shrine-diet-bioactivity/.env.template
#
# Copy to `.env` (gitignored) and fill in real values — or, preferred,
# pull from Infisical "SyntropyHealth App" project via:
#   infisical run -- <command>
#
# Never commit `.env` itself. Only this template (with empty values) ships.

# ---------------------------------------------------------------------------
# Neo4j Aura — knowledge graph backend
# Get values from: Neo4j Aura Console → instance → Connect tab
# ---------------------------------------------------------------------------
NEO4J_URI=neo4j+s://<instance-id>.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j
NEO4J_USER=neo4j

# ---------------------------------------------------------------------------
# LLM providers — used by LightRAG (production config) and Subsystem H agents
# ---------------------------------------------------------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ---------------------------------------------------------------------------
# Optional reranker (production config_production.env only)
# ---------------------------------------------------------------------------
JINA_API_KEY=

# ---------------------------------------------------------------------------
# Infisical (only if running outside `infisical run`)
# ---------------------------------------------------------------------------
INFISICAL_PROJECT_ID=
INFISICAL_CLIENT_ID=
INFISICAL_CLIENT_SECRET=
