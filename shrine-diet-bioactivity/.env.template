# Local development environment template — copy to `.env` and fill from
# Infisical "SyntropyHealth App" (or paste the live values).
# `.env` is gitignored; `.env.template` is tracked.

# Neo4j Aura Cloud connection
# Get from Aura console → your instance → Connect tab.
NEO4J_URI=neo4j+s://<instance-id>.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=<paste-from-aura-console>
NEO4J_DATABASE=neo4j
NEO4J_USER=neo4j

# OpenRouter — default LLM + embedding provider for both LightRAG and AG2 agents.
# Free tier: nvidia/nemotron-3-nano-30b-a3b:free (LLM), nvidia/llama-nemotron-embed-vl-1b-v2:free (embedder)
# Get a key at https://openrouter.ai/keys (free tier requires only signup).
OPENROUTER_API_KEY=<paste-from-openrouter-keys-page>

# Optional — only set if using non-default LightRAG storage backends
# WORKING_DIR=./rag_storage_local

# Optional fallbacks (only if OpenRouter is unreachable)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
