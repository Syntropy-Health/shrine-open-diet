# Local database
data_local
data_local_temp

# Source data archives (large files, download separately)
data/*.zip
data/*.tar.gz
data/*.gz

# Build output
build

# Dependencies
node_modules/

# Logs
*.log

# TypeScript cache
*.tsbuildinfo

# Coverage
coverage
*.lcov

# Editor
.idea
.vscode
.DS_Store

# Secrets (never commit)
.env
graphiti/.env
lightrag/.env

# LightRAG local storage (KV + vector DB files, ~54 MB)
lightrag/rag_storage_local/
lightrag/rag_storage_production/
rag_storage_local/
rag_storage_production/

# Raw source data dumps (CMAUP, TTD, BATMAN-TCM TSVs, ~115 MB)
data/cmaup-*.txt
data/ttd-*.txt
data/batman-tcm/

# SymMap v2.0 raw xlsx files (~4 MB total, download via make download-symmap)
data/symmap/

# HERB 2.0 cached JSON (download via make download-herb2, ~50-200 MB)
data/herb2/

# Python bytecode
__pycache__/
*.py[cod]
.pytest_cache/

# Audit log — per-tenant append-only, runtime-local (Phase A2)
lightrag/audit/
