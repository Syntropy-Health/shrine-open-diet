# LightRAG — Production Config (API models)
# Uses OpenAI embeddings + GPT-4o-mini LLM for high quality
# Jina multilingual reranker for Chinese+English TCM data
# Neo4j credentials via environment variables (never hardcode)

# Server
HOST=0.0.0.0
PORT=9621

# LLM — OpenAI API
LLM_BINDING=openai
LLM_BINDING_HOST=https://api.openai.com/v1
LLM_BINDING_API_KEY=${OPENAI_API_KEY}
LLM_MODEL=gpt-4o-mini

# Embedding — OpenAI API (large model for multilingual support)
EMBEDDING_BINDING=openai
EMBEDDING_BINDING_HOST=https://api.openai.com/v1
EMBEDDING_BINDING_API_KEY=${OPENAI_API_KEY}
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIM=3072
EMBEDDING_TOKEN_LIMIT=8192

# Storage — Neo4j graph + local file KV/vector
LIGHTRAG_GRAPH_STORAGE=Neo4JStorage
LIGHTRAG_KV_STORAGE=JsonKVStorage
LIGHTRAG_VECTOR_STORAGE=NanoVectorDBStorage
LIGHTRAG_DOC_STATUS_STORAGE=JsonDocStatusStorage
WORKING_DIR=./rag_storage_prod

# Neo4j — production (credentials from environment)
NEO4J_URI=${NEO4J_URI}
NEO4J_USERNAME=${NEO4J_USERNAME}
NEO4J_PASSWORD=${NEO4J_PASSWORD}
NEO4J_DATABASE=neo4j

# Workspace isolation
WORKSPACE=unified_diet_kg_prod

# Domain entity types — extended with TCM types for production
ENTITY_TYPES='["Herb","Compound","Food","Target","Disease","Symptom","Nutrient","TCM_Formula","Meridian","Organ"]'
SUMMARY_LANGUAGE=English

# Concurrency — higher for API
MAX_ASYNC=8
MAX_PARALLEL_INSERT=4

# Reranking — Jina multilingual (handles Chinese+English TCM data)
RERANK_BINDING=jina
RERANK_MODEL=jina-reranker-v2-base-multilingual
RERANK_BINDING_HOST=https://api.jina.ai/v1/rerank
RERANK_BINDING_API_KEY=${JINA_API_KEY}

# Query defaults
TOP_K=60
CHUNK_TOP_K=20
MAX_TOTAL_TOKENS=30000

# Cache
ENABLE_LLM_CACHE=true
ENABLE_LLM_CACHE_FOR_EXTRACT=true
