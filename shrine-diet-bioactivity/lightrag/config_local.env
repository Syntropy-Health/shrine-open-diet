# LightRAG — Default Config (OpenRouter)
# OpenRouter free tier: zero API cost, OpenAI-compatible endpoint.
# Neo4j on Aura Cloud — credentials via env vars / Infisical "SyntropyHealth App".

# Server
HOST=0.0.0.0
PORT=9621

# LLM — OpenRouter (NVIDIA Nemotron 3 Nano 30B A3B, free tier, 256K ctx, MoE)
LLM_BINDING=openai
LLM_BINDING_HOST=https://openrouter.ai/api/v1
LLM_MODEL=nvidia/nemotron-3-nano-30b-a3b:free
LLM_BINDING_API_KEY=${OPENROUTER_API_KEY}

# Embedding — OpenRouter (NVIDIA Llama Nemotron Embed VL 1B V2, free, dim 2048)
EMBEDDING_BINDING=openai
EMBEDDING_BINDING_HOST=https://openrouter.ai/api/v1
EMBEDDING_MODEL=nvidia/llama-nemotron-embed-vl-1b-v2:free
EMBEDDING_BINDING_API_KEY=${OPENROUTER_API_KEY}
EMBEDDING_DIM=2048
EMBEDDING_TIMEOUT=120

# Storage — Aura is the production source of truth for both graph and vectors.
# Per ADR 0001 (docs/adr/0001-vector-storage-on-aura.md):
#   - Graph: ScopedNeo4JStorage (subclass of Neo4JStorage with scope filter)
#   - Vector: ScopedNeo4JVectorStorage (Neo4j 5.13+ native vector index)
# To swap to local NanoVectorDB for fast pipeline iteration, override
# LIGHTRAG_VECTOR_STORAGE=NanoVectorDBStorage in your shell before starting
# the server. KV + DocStatus stay on local JSON for low-traffic metadata
# (small footprint, doesn't benefit from Aura round-trips).
LIGHTRAG_GRAPH_STORAGE=ScopedNeo4JStorage
LIGHTRAG_KV_STORAGE=JsonKVStorage
LIGHTRAG_VECTOR_STORAGE=ScopedNeo4JVectorStorage
LIGHTRAG_DOC_STATUS_STORAGE=JsonDocStatusStorage
WORKING_DIR=./rag_storage_local

# Neo4j — Aura Cloud (values injected from env / Infisical; no literals checked in)
NEO4J_URI=${NEO4J_URI}
NEO4J_USERNAME=${NEO4J_USERNAME}
NEO4J_PASSWORD=${NEO4J_PASSWORD}
NEO4J_DATABASE=${NEO4J_DATABASE:-neo4j}

# Workspace isolation
WORKSPACE=unified_diet_kg

# Domain entity types for extraction
ENTITY_TYPES='["Herb","Compound","Food","Target","Disease","Symptom","Nutrient"]'
SUMMARY_LANGUAGE=English

# Concurrency — OpenRouter free tier may rate-limit; keep modest
MAX_ASYNC=4
MAX_PARALLEL_INSERT=2
EMBEDDING_FUNC_MAX_ASYNC=4
EMBEDDING_BATCH_NUM=8

# Reranking — disabled for default config
RERANK_BINDING=null

# Query defaults
TOP_K=40
CHUNK_TOP_K=20
MAX_TOTAL_TOKENS=30000

# Cache
ENABLE_LLM_CACHE=true
ENABLE_LLM_CACHE_FOR_EXTRACT=true

# Reproducibility
SUBSAMPLE_SEED=42
